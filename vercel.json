{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm vercel-build",
  "installCommand": "pnpm install",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": false,
      "staging": false,
      "feature/*": false,
      "fix/*": false,
      "hotfix/*": false,
      "docs/*": false,
      "chore/*": false,
      "release/*": false
    }
  }
}
