# App
NODE_ENV=development

# Database (Postgres)
# Vercel/Neon: use the pooled Neon URL (ends in -pooler.<region>.aws.neon.tech)
# Local: any Postgres 16 instance is fine
DATABASE_URL=postgres://user:password@host:5432/gitcontrol

# DB driver — "neon" for Vercel + Neon, "node-postgres" for local Postgres / Docker
DB_DRIVER=node-postgres

# Used only by scripts/migrate.mjs during build.
# On Vercel + Neon set this to the *unpooled* Neon URL (DDL needs a direct connection).
MIGRATION_DATABASE_URL=

# Cache toggle. "false" skips Redis entirely (recommended on Vercel — zero infra).
# "true" requires REDIS_URL.
CACHE_ENABLED=false

# Redis (only required when CACHE_ENABLED=true)
REDIS_URL=

# GitHub OAuth App
# https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Token encryption (AES-256-GCM, 32 bytes hex = 64 chars)
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Better Auth
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Release webhook (used by .github/workflows/release.yml to invalidate
# the /changelog cache when a new release is published).
RELEASE_WEBHOOK_URL=

# Generate: openssl rand -hex 32
RELEASE_WEBHOOK_SECRET=
